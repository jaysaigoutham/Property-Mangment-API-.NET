{
  "ReverseProxy": {
    "Routes": {
      "identity": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/auth/{**catch-all}"
        }
      },
      "identity-users": {
        "ClusterId": "identity",
        "Match": {
          "Path": "/users/{**catch-all}"
        }
      },
      "listings": {
        "ClusterId": "listings",
        "Match": {
          "Path": "/listings/{**catch-all}"
        }
      },
      "media": {
        "ClusterId": "media",
        "Match": {
          "Path": "/media/{**catch-all}"
        }
      },
      "engagement-favorites": {
        "ClusterId": "engagement",
        "Match": {
          "Path": "/favorites/{**catch-all}"
        }
      },
      "engagement-saved-searches": {
        "ClusterId": "engagement",
        "Match": {
          "Path": "/saved-searches/{**catch-all}"
        }
      },
      "engagement-inquiries": {
        "ClusterId": "engagement",
        "Match": {
          "Path": "/inquiries/{**catch-all}"
        }
      },
      "engagement-reviews": {
        "ClusterId": "engagement",
        "Match": {
          "Path": "/reviews/{**catch-all}"
        }
      },
      "engagement-agents": {
        "ClusterId": "engagement",
        "Match": {
          "Path": "/agents/{**catch-all}"
        }
      },
      "admin": {
        "ClusterId": "admin",
        "Match": {
          "Path": "/admin/{**catch-all}"
        }
      },
      "notifications": {
        "ClusterId": "notifications",
        "Match": {
          "Path": "/notifications/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": {
          "identity-1": {
            "Address": "http://localhost:8081/"
          }
        }
      },
      "listings": {
        "Destinations": {
          "listings-1": {
            "Address": "http://localhost:8082/"
          }
        }
      },
      "media": {
        "Destinations": {
          "media-1": {
            "Address": "http://localhost:8083/"
          }
        }
      },
      "engagement": {
        "Destinations": {
          "engagement-1": {
            "Address": "http://localhost:8084/"
          }
        }
      },
      "admin": {
        "Destinations": {
          "admin-1": {
            "Address": "http://localhost:8086/"
          }
        }
      },
      "notifications": {
        "Destinations": {
          "notifications-1": {
            "Address": "http://localhost:8085/"
          }
        }
      }
    }
  },
  "Jwt": {
    "Issuer": "property-marketplace",
    "Audience": "property-marketplace",
    "SigningKey": "dev-only-signing-key-change-me-in-production-32",
    "AccessTokenMinutes": 60,
    "RefreshTokenDays": 14
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
